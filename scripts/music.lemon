// Big Core MK.I Custom Boss - Music Script
// Compatible with Sonic 3 A.I.R.

// Gradius Boss Music for Big Core MK.I
function void Music.Boss.AIZ1()
{
    // Play custom music defined in audio_replacements.json
    // The ID "aircraft_carrier" maps to Aircraft Carrier.ogg
    playMusic("aircraft_carrier")
}

// Function to stop music when boss is defeated or level ends
function void Music.Boss.Stop()
{
    // Return to normal zone music
    stopMusic()
    playMusic(0x01) // AIZ 1 Music ID
}
